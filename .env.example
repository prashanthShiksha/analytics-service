# Example .env file for analytics_service

# Kafka configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=analytics_ingestion_group
KAFKA_TOPIC=analytics.ingestion.raw

# Database configuration (asyncpg expects a DSN)
DATABASE_URL=postgresql://user:password@localhost:5432/analytics_db
RESET_DB=false

# Submission type configuration (comma‑separated list of allowed types)
SUBMISSION_TYPES=create,update,delete

# Temporal server configuration
TEMPORAL_ADDRESS=localhost:7233

# OpenRouter configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM runtime settings
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60
